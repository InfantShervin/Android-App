<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_upload"
            android:tint="@color/primary"
            android:padding="8dp"
            android:background="@drawable/rounded_tag_light" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/history_filename"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="passport.jpg"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />

            <TextView
                android:id="@+id/history_risk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH RISK"
                android:textSize="12sp"
                android:textColor="@color/risk_high"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/history_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="85%"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
